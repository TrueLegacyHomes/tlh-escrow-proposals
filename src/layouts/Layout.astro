---
interface Props {
  title?: string;
}

const { title = 'Escrow Proposals' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | True Legacy Homes</title>
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}leaf-small.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-white border-b border-[var(--color-cream-dark)] sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center gap-3">
            <img src={`${import.meta.env.BASE_URL}leaf-small.png`} alt="TLH" class="w-8 h-8 object-contain" />
            <div>
              <span class="text-lg font-bold text-[var(--color-charcoal)]">Escrow & Title Proposals</span>
              <span class="hidden sm:inline text-sm text-[var(--color-gray-warm)] ml-2">True Legacy Homes</span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-white border-t border-[var(--color-cream-dark)] mt-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <img src={`${import.meta.env.BASE_URL}leaf-small.png`} alt="TLH" class="h-5 w-5 opacity-50" />
          <span class="text-xs text-[var(--color-gray-warm)]">True Legacy Homes &copy; {new Date().getFullYear()}</span>
        </div>
        <span class="text-xs text-[var(--color-gray-warm)]">Internal Tool v1.0</span>
      </div>
    </footer>
  </body>
</html>

<style>
  @import '../styles/global.css';
</style>
